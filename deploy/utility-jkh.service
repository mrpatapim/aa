[Unit]
Description=Utility JKH FastAPI application
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/utility-jkh
EnvironmentFile=/opt/utility-jkh/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/utility-jkh/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
