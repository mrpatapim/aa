# Скопируйте в .deploy.env и заполните значения.
# Файл .deploy.env не должен попадать в git.
#
# Ubuntu: bash scripts/deploy.sh  (НЕ deploy.ps1)
# Уже на сервере с кодом: bash scripts/deploy-local.sh

# SSH-подключение
DEPLOY_HOST=203.0.113.10
DEPLOY_USER=deploy
DEPLOY_PORT=22
# Путь к приватному ключу (опционально; пусто = ключ по умолчанию)
DEPLOY_SSH_KEY=

# Каталог приложения на сервере
DEPLOY_PATH=/opt/utility-jkh

# Имя systemd-сервиса (создаётся скриптом server-bootstrap.sh)
DEPLOY_SERVICE=utility-jkh

# URL для проверки после деплоя (опционально)
# DEPLOY_HEALTH_URL=http://203.0.113.10/docs
